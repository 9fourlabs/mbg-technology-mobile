[
  {
    "id": "services0000000",
    "name": "services",
    "type": "base",
    "schema": [
      { "name": "name",        "type": "text",   "required": true },
      { "name": "description", "type": "text" },
      { "name": "duration",    "type": "number", "required": true, "options": { "min": 1 } },
      { "name": "price",       "type": "number", "required": true, "options": { "min": 0 } },
      { "name": "active",      "type": "bool" },
      { "name": "sort_order",  "type": "number" }
    ],
    "listRule":   "@request.auth.id != '' && active = true",
    "viewRule":   "@request.auth.id != '' && active = true",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  },
  {
    "id": "timeslots000000",
    "name": "time_slots",
    "type": "base",
    "schema": [
      { "name": "service",          "type": "relation", "required": true, "options": { "collectionId": "services0000000", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "date",             "type": "date",     "required": true },
      { "name": "start_time",       "type": "text",     "required": true, "options": { "pattern": "^[0-2][0-9]:[0-5][0-9](:[0-5][0-9])?$" } },
      { "name": "end_time",         "type": "text",     "required": true, "options": { "pattern": "^[0-2][0-9]:[0-5][0-9](:[0-5][0-9])?$" } },
      { "name": "max_bookings",     "type": "number",   "required": true, "options": { "min": 1 } },
      { "name": "current_bookings", "type": "number",   "required": true, "options": { "min": 0 } }
    ],
    "indexes": [
      "CREATE UNIQUE INDEX idx_time_slots_service_date_start ON time_slots (service, date, start_time)",
      "CREATE INDEX idx_time_slots_service_date ON time_slots (service, date)"
    ],
    "listRule":   "@request.auth.id != '' && current_bookings < max_bookings",
    "viewRule":   "@request.auth.id != '' && current_bookings < max_bookings",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  },
  {
    "id": "bookings0000000",
    "name": "bookings",
    "type": "base",
    "schema": [
      { "name": "user",      "type": "relation", "required": true, "options": { "collectionId": "_pb_users_auth_", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "service",   "type": "relation", "required": true, "options": { "collectionId": "services0000000", "cascadeDelete": false, "maxSelect": 1 } },
      { "name": "time_slot", "type": "relation", "required": true, "options": { "collectionId": "timeslots000000", "cascadeDelete": false, "maxSelect": 1 } },
      { "name": "status",    "type": "select",   "required": true, "options": { "maxSelect": 1, "values": ["confirmed", "cancelled", "completed", "no_show"] } },
      { "name": "notes",     "type": "text" }
    ],
    "indexes": [
      "CREATE INDEX idx_bookings_user_status ON bookings (user, status)",
      "CREATE INDEX idx_bookings_time_slot ON bookings (time_slot)"
    ],
    "listRule":   "@request.auth.id != '' && user = @request.auth.id",
    "viewRule":   "@request.auth.id != '' && user = @request.auth.id",
    "createRule": "@request.auth.id != '' && user = @request.auth.id",
    "updateRule": "@request.auth.id != '' && user = @request.auth.id",
    "deleteRule": "@request.auth.id != '' && user = @request.auth.id"
  }
]
