[
  {
    "id": "tenants_admin01",
    "name": "tenants",
    "type": "base",
    "schema": [
      { "name": "slug",                    "type": "text", "required": true, "unique": true, "options": { "pattern": "^[a-z0-9-]+$" } },
      { "name": "business_name",           "type": "text", "required": true },
      { "name": "template_type",           "type": "text", "required": true, "options": { "values": ["informational", "authenticated", "booking", "commerce", "loyalty", "content", "forms", "directory", "custom"] } },
      { "name": "status",                  "type": "select", "required": true, "options": { "values": ["draft", "preview", "production"], "maxSelect": 1 } },
      { "name": "config",                  "type": "json",   "options": { "maxSize": 2000000 } },
      { "name": "supabase_project_id",     "type": "text" },
      { "name": "supabase_url",            "type": "url" },
      { "name": "supabase_anon_key",       "type": "text" },
      { "name": "expo_project_id",         "type": "text" },
      { "name": "app_version",             "type": "text" },
      { "name": "created_by",              "type": "text" },
      { "name": "app_type",                "type": "select", "options": { "values": ["template", "custom"], "maxSelect": 1 } },
      { "name": "repo_url",                "type": "url" },
      { "name": "repo_branch",             "type": "text" },
      { "name": "appetize_public_key",     "type": "text" },
      { "name": "appetize_public_key_ios", "type": "text" },
      { "name": "brief",                   "type": "json",   "options": { "maxSize": 2000000 } },
      { "name": "pocketbase_url",          "type": "url" },
      { "name": "pocketbase_app_name",     "type": "text" },
      { "name": "backend",                 "type": "select", "options": { "values": ["supabase", "pocketbase"], "maxSelect": 1 } }
    ],
    "indexes": [
      "CREATE UNIQUE INDEX idx_tenants_slug ON tenants (slug)",
      "CREATE INDEX idx_tenants_status ON tenants (status)"
    ],
    "listRule":   null,
    "viewRule":   null,
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  },
  {
    "id": "builds_admin001",
    "name": "builds",
    "type": "base",
    "schema": [
      { "name": "tenant",                  "type": "relation", "required": true, "options": { "collectionId": "tenants_admin01", "cascadeDelete": true, "maxSelect": 1 } },
      { "name": "workflow_run_id",         "type": "text" },
      { "name": "platform",                "type": "select", "options": { "values": ["ios", "android", "all"], "maxSelect": 1 } },
      { "name": "profile",                 "type": "select", "options": { "values": ["preview", "production", "development"], "maxSelect": 1 } },
      { "name": "status",                  "type": "select", "required": true, "options": { "values": ["pending", "in_progress", "succeeded", "failed", "cancelled"], "maxSelect": 1 } },
      { "name": "build_url",               "type": "url" },
      { "name": "download_url",            "type": "url" },
      { "name": "download_url_ios",        "type": "url" },
      { "name": "error_message",           "type": "text" },
      { "name": "app_version",             "type": "text" },
      { "name": "eas_build_id_android",    "type": "text" },
      { "name": "eas_build_id_ios",        "type": "text" },
      { "name": "appetize_public_key",     "type": "text" },
      { "name": "appetize_public_key_ios", "type": "text" },
      { "name": "config_hash",             "type": "text" }
    ],
    "indexes": [
      "CREATE INDEX idx_builds_tenant ON builds (tenant)",
      "CREATE INDEX idx_builds_status ON builds (status)",
      "CREATE INDEX idx_builds_created ON builds (created DESC)"
    ],
    "listRule":   null,
    "viewRule":   null,
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  },
  {
