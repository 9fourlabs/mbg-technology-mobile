      { "name": "role",       "type": "select",   "required": true, "options": { "values": ["admin", "client"], "maxSelect": 1 } }
    ],
    "indexes": [
      "CREATE UNIQUE INDEX idx_tenant_users_pair ON tenant_users (user, tenant)",
      "CREATE INDEX idx_tenant_users_user ON tenant_users (user)",
