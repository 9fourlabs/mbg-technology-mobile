# Plaintext example of admin/.env.local.
#
# Prefer generating the real file from .env.local.tpl via:
#   op inject -i admin/.env.local.tpl -o admin/.env.local
#
# Use this example only as a reference for what variables are required.
# Never commit the real .env.local — it is gitignored.

# --- Admin Supabase (central mbg-admin project) ---
NEXT_PUBLIC_SUPABASE_URL=https://wmckytfxlcxzhzduttvv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...                          # anon key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                              # service_role key, bypasses RLS

# Supabase Management API PAT (for per-tenant provisioning)
SUPABASE_ACCESS_TOKEN=sbp_...

# --- EAS ---
EXPO_TOKEN=your-expo-access-token

# --- GitHub ---
GITHUB_TOKEN=github_pat_...                                          # fine-grained PAT, Actions+Contents RW on this repo
GITHUB_REPO=9fourlabs/mbg-technology-mobile

# --- Build link HMAC signing ---
ADMIN_BUILD_LINK_SECRET=32+chars-of-randomness

# --- Optional: Appetize ---
# APPETIZE_API_KEY=appetize-key
