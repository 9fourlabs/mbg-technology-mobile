{
  "name": "mbg-technology-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:tenants": "tsx scripts/generateTenants.ts && tsx scripts/generateTenantIndex.ts",
    "validate:tenants": "tsx scripts/validateTenants.ts",
    "new-tenant": "tsx scripts/newTenant.ts",
    "generate:keystore": "bash scripts/generateKeystore.sh",
    "validate:production": "tsx scripts/validateProductionReady.ts",
    "ota:preview": "tsx scripts/publishOta.ts preview",
    "ota:production": "tsx scripts/publishOta.ts production",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": { "^.+\\.tsx?$": ["ts-jest", { "isolatedModules": true }] },
    "testMatch": ["<rootDir>/__tests__/**/*.test.ts"],
    "testPathIgnorePatterns": ["/node_modules/", "/admin/"],
    "modulePathIgnorePatterns": ["<rootDir>/admin/"]
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.100.1",
    "expo": "~55.0.17",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-notifications": "~55.0.20",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
